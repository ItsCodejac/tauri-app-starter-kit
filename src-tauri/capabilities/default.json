{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the app starter template",
  "windows": ["main", "splash", "settings", "about", "shortcuts", "logs", "update", "whatsnew", "welcome"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-fullscreen",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-is-fullscreen",
    "core:window:allow-is-maximized",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:default",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-appcache-read",
    "fs:allow-appcache-write",
    "fs:allow-appconfig-read",
    "fs:allow-appconfig-write",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-applog-read",
    "fs:allow-applog-write",
    "shell:default",
    "shell:allow-open",
    "opener:default",
    "store:default",
    "window-state:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "os:default",
    "process:default",
    "process:allow-restart",
    "process:allow-exit",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "core:window:allow-set-always-on-top",
    "keyring:default",
    "keyring:allow-set-password",
    "keyring:allow-delete-password",
    "normalize:default"
  ]
}
